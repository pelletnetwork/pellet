{
  "name": "pellet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "fumadocs-mdx && next dev",
    "build": "fumadocs-mdx && next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "seed:services": "tsx --env-file=.env.local scripts/seed-services.ts",
    "label-provider": "tsx --env-file=.env.local scripts/label-provider.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "fumadocs-core": "^16.8.5",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.5",
    "geist": "^1.7.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
